.DS_Store
.venv/
__pycache__/
*.pyc

# Local artifacts
mlflow.db
mlruns/
**/.DS_Store
.ipynb_checkpoints/

# Data — never commit raw or processed data
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Generated artifacts
figures/*
!figures/.gitkeep
*.pkl
*.joblib

# Serialised model artefacts (timestamped .joblib files from export.save_model)
models/*
!models/.gitkeep

# dbt
dbt/target/
dbt/logs/
dbt/dbt_packages/
